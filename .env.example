# MyQuota App — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env — it's in .gitignore

# ===========================================
# API Configuration
# ===========================================
# Base URL for the backend API (include /api suffix)
EXPO_PUBLIC_API_BASE_URL=https://your-backend.up.railway.app/api

# ===========================================
# App Configuration
# ===========================================
# Deep-link scheme for the app (used in expo-router and native configs)
EXPO_PUBLIC_APP_SCHEME=myapp

# ===========================================
# EAS / Expo Updates
# ===========================================
# EAS Project ID (from EAS Dashboard)
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id

# Expo Updates URL (from EAS Dashboard, format: https://u.expo.dev/{projectId})
EXPO_PUBLIC_EXPO_UPDATES_URL=https://u.expo.dev/your-eas-project-id

# ===========================================
# Google OAuth (Google Sign-In)
# ===========================================
# Web Client ID (from Google Cloud Console — OAuth 2.0 Client IDs)
EXPO_PUBLIC_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# iOS Client ID (from Google Cloud Console)
EXPO_PUBLIC_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# iOS URL Scheme for Google Sign-In (from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=com.googleusercontent.apps.your-ios-client-id
